# ========================================
# 环境变量配置模板
# ========================================
# 复制此文件为 .env.local，然后填入你的实际配置

# ========================================
# MongoDB 数据库配置（免费）
# ========================================
# 获取方式：https://www.mongodb.com/cloud/atlas/register
# 1. 注册 MongoDB Atlas 账号
# 2. 创建免费集群
# 3. 创建数据库用户（记下用户名和密码）
# 4. 获取连接字符串，格式：mongodb+srv://用户名:密码@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job-tracker

# ========================================
# 百度 OCR API 配置（免费）
# ========================================
# 获取方式：https://cloud.baidu.com/product/ocr
# 1. 登录/注册百度账号
# 2. 进入控制台创建应用：https://console.bce.baidu.com/ai/#/ai/ocr/app/list
# 3. 创建后获取 API Key 和 Secret Key

# 百度 OCR API Key (Client ID)
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key_here

# 百度 OCR Secret Key (Client Secret)
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key_here

# ========================================
# 说明
# ========================================
# - .env.local 文件不会提交到 Git（已在 .gitignore 中）
# - 配置完成后需要重启开发服务器
# - 不配置 MongoDB/OCR 也可以使用，会自动切换到本地文件模式
